{
  "openapi": "3.0.0",
  "info": {
    "title": "Etamen Diabetes Backend API",
    "description": "API documentation for the Etamen diabetes tracking application.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost/api",
      "description": "Local server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "full_name": { "type": "string" },
          "email": { "type": "string" },
          "birth_date": { "type": "string", "format": "date" },
          "gender": { "type": "string", "enum": ["male", "female", "other"] },
          "diabetes_type": { "type": "string", "enum": ["type1", "type2", "gestational"] },
          "target_min": { "type": "integer" },
          "target_max": { "type": "integer" }
        }
      },
      "Reading": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "value": { "type": "integer" },
          "timestamp": { "type": "string", "format": "date-time" },
          "context": { "type": "string" },
          "status": { "type": "string", "enum": ["Low", "Normal", "Warning", "High"] },
          "notes": { "type": "string", "nullable": true }
        }
      },
      "Reminder": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "time": { "type": "string", "example": "08:00" },
          "label": { "type": "string" },
          "days": {
            "type": "array",
            "items": { "type": "string" }
          },
          "is_active": { "type": "boolean" }
        }
      }
    }
  },
  "paths": {
    "/register": {
      "post": {
        "summary": "Register a new user",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["full_name", "email", "password"],
                "properties": {
                  "full_name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string", "minLength": 8 },
                  "birth_date": { "type": "string", "format": "date" },
                  "gender": { "type": "string" },
                  "diabetes_type": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": { "type": "string" },
                    "token_type": { "type": "string" },
                    "user": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/login": {
      "post": {
        "summary": "Login user",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": { "type": "string" },
                    "token_type": { "type": "string" },
                    "user": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/logout": {
      "post": {
        "summary": "Logout user",
        "tags": ["Auth"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Successfully logged out" }
        }
      }
    },
    "/home": {
      "get": {
        "summary": "Get dashboard summary",
        "tags": ["General"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "User home data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "full_name": { "type": "string" },
                    "last_reading": { "$ref": "#/components/schemas/Reading" },
                    "streak": { "type": "integer" },
                    "target_range": {
                      "type": "object",
                      "properties": {
                        "min": { "type": "integer" },
                        "max": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/readings": {
      "get": {
        "summary": "List readings (grouped by day)",
        "tags": ["Readings"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "date", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of grouped readings" }
        }
      },
      "post": {
        "summary": "Add new reading",
        "tags": ["Readings"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["value", "timestamp", "context"],
                "properties": {
                  "value": { "type": "integer" },
                  "timestamp": { "type": "string", "format": "date-time" },
                  "context": { "type": "string" },
                  "notes": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Reading created" }
        }
      }
    },
    "/readings/{id}": {
      "get": {
        "summary": "Get single reading",
        "tags": ["Readings"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Reading details" } }
      },
      "put": {
        "summary": "Update reading",
        "tags": ["Readings"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Reading updated" } }
      },
      "delete": {
        "summary": "Delete reading",
        "tags": ["Readings"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Reading deleted" } }
      }
    },
    "/stats/summary": {
      "get": {
        "summary": "Get statistical summary",
        "tags": ["Stats"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Summary of averages, trends, and status counts" }
        }
      }
    },
    "/stats/chart": {
      "get": {
        "summary": "Get chart data",
        "tags": ["Stats"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "period", "in": "query", "schema": { "type": "string", "enum": ["week", "month"] } }],
        "responses": { "200": { "description": "Time-series data for charts" } }
      }
    },
    "/reminders": {
      "get": {
        "summary": "List reminders",
        "tags": ["Reminders"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "List of user reminders" } }
      },
      "post": {
        "summary": "Create reminder",
        "tags": ["Reminders"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["time", "label", "days"],
                "properties": {
                  "time": { "type": "string" },
                  "label": { "type": "string" },
                  "days": { "type": "array", "items": { "type": "string" } },
                  "is_active": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Reminder created" } }
      }
    },
    "/reminders/{id}": {
      "put": {
        "summary": "Update reminder",
        "tags": ["Reminders"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "time": { "type": "string" },
                  "label": { "type": "string" },
                  "days": { "type": "array", "items": { "type": "string" } },
                  "is_active": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Reminder updated" } }
      },
      "delete": {
        "summary": "Delete reminder",
        "tags": ["Reminders"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Reminder deleted" } }
      }
    }
  }
}
